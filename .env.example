GATEWAY_API_KEY=your_gateway_api_key

GOOGLE_AI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# ── 로컬 Realtime(음성) 파이프라인 (선택 — model=local-live) ──────────────
# 전부 기본값이 있어 비워도 된다. 상세 설명은 app/config.py 참고.
# 음성 대화용 LLM. 기본은 DEFAULT_MODEL과 같은 qwen3:14b(상주 모델 재사용).
# 더 빠른 첫 응답이 필요하면 ollama/qwen3.5:9b 등으로 교체(docs/ollama-bench-2026-07.md).
REALTIME_LOCAL_LLM_MODEL=
# 음성 턴 하나의 LLM 출력 상한(토큰). 기본 200. 0 이하면 무제한.
REALTIME_LOCAL_LLM_MAX_TOKENS=
# STT(faster-whisper) 크기(tiny/base/small/medium)와 디바이스(cpu/cuda). 기본 small/cpu.
# cuda는 LLM과 VRAM을 나눠 쓰므로 음성 LLM을 경량화했을 때만 켤 것(실패 시 cpu 폴백).
REALTIME_LOCAL_STT_MODEL=
REALTIME_LOCAL_STT_DEVICE=
# VAD 발화 종료 판정 침묵(ms). 기본 700.
REALTIME_LOCAL_VAD_SILENCE_MS=
